DATABASE_URL=postgresql://snake:ТВОЙ_ПАРОЛЬ@127.0.0.1:5432/snake_attack

# Или по отдельности (удобно если в пароле есть @ # и т.д.):
# PGUSER=snake
# PGPASSWORD=ТВОЙ_ПАРОЛЬ
# PGHOST=127.0.0.1
# PGPORT=5432
# PGDATABASE=snake_attack

PORT=8080
HOST=127.0.0.1

# Публичный URL сайта (без слэша в конце) — для Google OAuth redirect
PUBLIC_URL=https://dastogram.ru

# Google OAuth (Google Cloud Console → APIs & Services → Credentials)
# Authorized redirect URIs (добавь ОБА если тестируешь локально):
#   https://dastogram.ru/auth/google/callback
#   http://localhost:8080/auth/google/callback
# Authorized JavaScript origins (опционально):
#   https://dastogram.ru
#   http://localhost:8080
GOOGLE_CLIENT_ID=ваш-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=ваш-client-secret
SESSION_SECRET=случайная-длинная-строка-минимум-32-символа

# Или явно задать callback (перебивает PUBLIC_URL):
# GOOGLE_REDIRECT_URI=https://dastogram.ru/auth/google/callback
