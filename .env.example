DATABASE_URL=postgresql://snake:ТВОЙ_ПАРОЛЬ@127.0.0.1:5432/snake_attack

# Или по отдельности (удобно если в пароле есть @ # и т.д.):
# PGUSER=snake
# PGPASSWORD=ТВОЙ_ПАРОЛЬ
# PGHOST=127.0.0.1
# PGPORT=5432
# PGDATABASE=snake_attack

PORT=8080
HOST=127.0.0.1

# Публичный URL сайта (без слэша в конце) — для health/info эндпоинтов
PUBLIC_URL=https://dastogram.ru

# Авторизация — локальная (логин/пароль), без внешних провайдеров.
# Список никнеймов через запятую, у которых всегда есть админ-доступ
# (и которых нельзя забанить/удалить через админку) — необязательно.
ADMIN_USERNAMES=
